{
  "name": "gracefulerrors",
  "version": "0.1.2",
  "description": "Transform technical errors into consistent, user-friendly experiences",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./sonner": {
      "types": "./dist/adapters/sonner.d.ts",
      "import": "./dist/adapters/sonner.mjs",
      "require": "./dist/adapters/sonner.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.cjs"
    },
    "./axios": {
      "types": "./dist/axios.d.ts",
      "import": "./dist/axios.mjs",
      "require": "./dist/axios.cjs"
    },
    "./react-hot-toast": {
      "types": "./dist/adapters/react-hot-toast.d.ts",
      "import": "./dist/adapters/react-hot-toast.mjs",
      "require": "./dist/adapters/react-hot-toast.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.cjs"
    },
    "./reporters": {
      "types": "./dist/reporters/index.d.ts",
      "import": "./dist/reporters/index.mjs",
      "require": "./dist/reporters/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:types": "npm run build",
    "test:types": "tsd",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "peerDependencies": {
    "axios": ">=1",
    "react": ">=18",
    "react-dom": ">=18",
    "react-hot-toast": ">=2",
    "sonner": ">=1",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "sonner": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-hot-toast": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "axios": {
      "optional": true
    }
  },
  "tsd": {
    "directory": "src/__tests__"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hot-toast": "^2.6.0",
    "sonner": "^1.0.0",
    "tsd": "^0.31.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^1.0.0",
    "vue": "^3.5.32"
  }
}
