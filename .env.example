# Environment Variables for gracefulerrors

# Set the Node.js environment
# Values: development, production, test
NODE_ENV=development

# Optional: Log level for debugging
# Values: debug, info, warn, error
LOG_LEVEL=info

# Optional: Enable source maps in production
GENERATE_SOURCEMAP=true

# Optional: Port for development server (if used)
PORT=3000

# Optional: API endpoint for integration tests or examples
API_URL=http://localhost:3000

# Optional: Enable debug mode for verbose logging
DEBUG=gracefulerrors:*
